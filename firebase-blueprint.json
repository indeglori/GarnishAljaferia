{
  "entities": {
    "Reservation": {
      "title": "Reservation",
      "description": "A table reservation at Garnish.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Customer name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Customer contact email"
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "Reservation date"
        },
        "time": {
          "type": "string",
          "description": "Reservation time (HH:mm)"
        },
        "guests": {
          "type": "string",
          "description": "Number of guests"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the reservation was created"
        }
      },
      "required": ["name", "email", "date", "time", "guests", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A customer review.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Customer name"
        },
        "rating": {
          "type": "number",
          "description": "Rating out of 5"
        },
        "comment": {
          "type": "string",
          "description": "Review text"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the review was created"
        }
      },
      "required": ["name", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "reservations": {
      "schema": "Reservation",
      "description": "Collection of table reservations."
    },
    "reviews": {
      "schema": "Review",
      "description": "Collection of customer reviews."
    }
  }
}
